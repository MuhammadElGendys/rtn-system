        "id": "ad1a88417076cbb6",
        "type": "function",
        "z": "74495d5772959a6b",
        "name": "parse control",
        "func": "let body = msg.payload || {};\n\nlet motorMsg = null;\nlet alarmMsg = null;\n\nif (body.motorRun !== undefined) {\n    motorMsg = { payload: !!body.motorRun };\n}\n\nif (body.alarmActive !== undefined) {\n    alarmMsg = { payload: !!body.alarmActive };\n}\n\nlet responseMsg = {\n    headers: { \"Content-Type\": \"application/json\" },\n    payload: { ok: true, message: \"Control command sent\" }\n};\n\nreturn [motorMsg, alarmMsg, responseMsg];",
