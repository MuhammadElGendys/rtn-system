    {
        "id": "3a5e17a3fb65345a",
        "type": "function",
        "z": "74495d5772959a6b",
        "name": "Get History",
        "func": "let limit = 50;\n\nif (msg.req && msg.req.query && msg.req.query.limit) {\n    limit = parseInt(msg.req.query.limit, 10) || 50;\n}\n\nmsg.topic = `\nSELECT ts, pressure, motorRun, temperature, speedRPM, alarmActive\nFROM plc_history\nORDER BY id DESC\nLIMIT ${limit};\n`;\n\nreturn msg;",
