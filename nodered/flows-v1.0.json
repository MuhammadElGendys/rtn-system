        "func": "let data = flow.get(\"latestData\") || {};\n\nif (msg.topic === \"pressure\") data.pressure = msg.payload;\nif (msg.topic === \"motorRun\") data.motorRun = msg.payload;\nif (msg.topic === \"temperature\") data.temperature = msg.payload;\nif (msg.topic === \"speedRPM\") data.speedRPM = msg.payload;\nif (msg.topic === \"alarmActive\") data.alarmActive = msg.payload;\n\ndata.ts = new Date().toISOString();\n\nflow.set(\"latestData\", data);\n\nmsg.payload = data;\nreturn msg;",
