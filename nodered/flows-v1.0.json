    {
        "id": "32f522ab016c1ba5",
        "type": "function",
        "z": "74495d5772959a6b",
        "name": "Insert latest into DB",
        "func": "let d = msg.payload || {};\n\nmsg.topic = `\nINSERT INTO plc_history (ts, pressure, motorRun, temperature, speedRPM, alarmActive)\nVALUES (\n  '${d.ts || new Date().toISOString()}',\n  ${Number(d.pressure || 0)},\n  ${d.motorRun ? 1 : 0},\n  ${Number(d.temperature || 0)},\n  ${Number(d.speedRPM || 0)},\n  ${d.alarmActive ? 1 : 0}\n);\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
